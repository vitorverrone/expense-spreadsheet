{
    "$schema": "https://turborepo.org/schema.json",
    "tasks": {
        "dev": {
            "cache": false
        },
        "test:ui": {
            "cache": false
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "env": [
                "API_URL",
                "JWT_SECRET",
                "NEXT_PUBLIC_API_URL",
                "NODE_ENV"
            ],
            "outputs": [
                "dist/**",
                ".next/**"
            ]
        }
    }
}